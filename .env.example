# PostgreSQL credentials
POSTGRES_USER=store_user
POSTGRES_PASSWORD=store_password

# Database connection URL (used by API and Alembic)
DATABASE_URL=postgresql://store_user:store_password@db:5432/store_intelligence

# API base URL (used by pipeline and dashboard)
API_BASE_URL=http://localhost:8000

# Path to the YOLOv8 model weights file
YOLO_MODEL_PATH=yolov8n.pt

# Minimum seconds a visitor must remain in a zone before a ZONE_DWELL event is emitted
DWELL_THRESHOLD_SECONDS=30

# Seconds a visitor can be in the billing queue without a POS transaction before BILLING_QUEUE_ABANDON is emitted
QUEUE_ABANDON_TIMEOUT_SECONDS=120

# Redis connection URL (used for job queue, pub/sub, rate limiting, and caching)
REDIS_URL=redis://redis:6379/0

# JWT secret key used to sign authentication tokens (change this in production!)
JWT_SECRET=dev-secret-change-in-production

# Video storage backend: 'local' (default) stores files on disk, 's3' stores files in Amazon S3
STORAGE_BACKEND=local

# Local storage path (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=data/videos

# S3 storage configuration (used when STORAGE_BACKEND=s3)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key

# Number of days to retain uploaded videos before automatic deletion (default: 90)
RETENTION_DAYS=90

# Time of day (UTC) to run the daily storage cleanup job, in HH:MM format (default: 02:00)
CLEANUP_TIME_UTC=02:00

# Whether to transcode unsupported video codecs to H.264 before processing (true/false)
# Set to true to allow AVI/MOV files with non-standard codecs; requires ffmpeg in PATH
TRANSCODE_UNSUPPORTED=false
